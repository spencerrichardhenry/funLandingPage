---
const iam = [
  'Neuroscience degree, CS minor',
  'Full-stack software engineer',
  'Worked on the Developer Experience team for 1000+ devs',
  'A man of many opinions'
];
const iamnot = [
  'A machine learning expert',
  'A computer science expert',
  'A disciple of any particular guru',
  'An LLM fanatic, or doomer',
];
---

<section id="why-me" class="section why-me-section">
  <div class="container">
    <div class="dos-prompt">
      <span class="dos-path">C:\LECTURE\SPEAKER&gt;</span>
      <span class="dos-cmd"> whoami</span>
      <span class="dos-cursor">_</span>
    </div>

    <div class="dos-output">
      <p>User: SPENCER_HENRY</p>
      <p>Role: Senior Software Engineer @ Guardian</p>
      <p>Loading credentials...</p>
    </div>

    <div class="split-table">
      <div class="split-col split-col-yes">
        <div class="split-header split-header-yes">
          <h2 class="split-heading">WHO I AM</h2>
        </div>
        <ul class="split-list">
          {iam.map((item) => (
            <li class="split-item">
              <span class="split-bullet split-bullet-yes">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="split-divider"></div>
      <div class="split-col split-col-no">
        <div class="split-header split-header-no">
          <h2 class="split-heading">WHO I AM NOT</h2>
        </div>
        <ul class="split-list">
          {iamnot.map((item) => (
            <li class="split-item">
              <span class="split-bullet split-bullet-no">✗</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="tldr-box">
      <div class="tldr-header win95-raised">
        <span class="tldr-dots">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
        </span>
        <span class="tldr-label">tl;dr.exe</span>
      </div>
      <div class="tldr-body">
        <p>I'm a regular industry dude who uses agentic AI daily. I've fiddled with LLMs as part of my workflows since GPT-3, but only really went all-in on an AI first workflow about 6 months ago.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .why-me-section {
    background-color: #FFFFFF;
    background-image:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 59px,
        rgba(0, 102, 255, 0.06) 59px,
        rgba(0, 102, 255, 0.06) 60px
      );
  }

  .dos-prompt {
    font-family: var(--font-body);
    font-size: 28px;
    margin-bottom: 8px;
    color: #222;
  }

  .dos-path {
    color: var(--blue);
  }

  .dos-cmd {
    color: #222;
  }

  .dos-cursor {
    animation: blink 1s step-end infinite;
    color: var(--green);
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .dos-output {
    font-family: var(--font-body);
    font-size: 20px;
    color: #666;
    padding: 8px 0 16px;
    border-bottom: 2px dashed #ddd;
    margin-bottom: 32px;
  }

  .dos-output p {
    margin-bottom: 2px;
  }

  /* Split table */
  .split-table {
    display: flex;
    border: var(--border-thick);
    box-shadow: var(--shadow-boxy);
    background: white;
    margin-bottom: 40px;
    overflow: hidden;
  }

  .split-col {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .split-divider {
    width: 4px;
    background: #222;
    flex-shrink: 0;
  }

  .split-header {
    padding: 12px 20px;
    border-bottom: 3px solid #222;
  }

  .split-header-yes {
    background: #E8F5E9;
  }

  .split-header-no {
    background: #FFEBEE;
  }

  .split-heading {
    font-family: var(--font-heading);
    font-size: clamp(10px, 1.5vw, 14px);
    text-align: center;
    margin-bottom: 0;
  }

  .split-header-yes .split-heading {
    color: var(--green);
  }

  .split-header-no .split-heading {
    color: var(--red);
  }

  .split-list {
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex: 1;
  }

  .split-item {
    display: flex;
    gap: 10px;
    align-items: baseline;
    font-family: var(--font-body);
    font-size: 22px;
    color: #444;
    line-height: 1.4;
  }

  .split-bullet {
    font-weight: bold;
    font-size: 20px;
    flex-shrink: 0;
  }

  .split-bullet-yes {
    color: var(--green);
  }

  .split-bullet-no {
    color: var(--red);
  }

  /* TL;DR window */
  .tldr-box {
    border: var(--border-thick);
    box-shadow: var(--shadow-boxy);
    overflow: hidden;
  }

  .tldr-header {
    background: var(--bg-gray);
    padding: 6px 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 2px solid #999;
  }

  .tldr-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-red { background: var(--red); }
  .dot-yellow { background: var(--yellow); }
  .dot-green { background: var(--green); }

  .tldr-label {
    font-family: var(--font-ui);
    font-size: 11px;
    color: #444;
  }

  .tldr-body {
    padding: 20px;
    background: var(--bg-white);
  }

  .tldr-body p {
    font-family: var(--font-body);
    font-size: 22px;
    color: #444;
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .split-table {
      flex-direction: column;
    }
    .split-divider {
      width: 100%;
      height: 4px;
    }
  }
</style>
