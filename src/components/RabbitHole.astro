---
const links = [
  {
    category: 'WATCH',
    items: [
      { name: 'Andrej Karpathy — "Intro to LLMs"', url: 'https://www.youtube.com/watch?v=zjkBMFhNj_g', desc: 'The best 1-hour intro to how LLMs actually work' },
      { name: 'Fireship — "God-Tier Developer Roadmap"', url: 'https://www.youtube.com/watch?v=pEfrdAtAmqk', desc: 'What skills matter in 2026 and beyond' },
      { name: '3Blue1Brown — "But what is a GPT?"', url: 'https://www.youtube.com/watch?v=wjZofJX0v4M', desc: 'Beautiful visual explanation of transformers' },
    ],
  },
  {
    category: 'READ',
    items: [
      { name: 'Simon Willison\'s Blog', url: 'https://simonwillison.net/', desc: 'The best AI-for-developers blog on the internet' },
      { name: 'Anthropic Research', url: 'https://www.anthropic.com/research', desc: 'Papers and posts from the Claude team' },
      { name: '"The Pragmatic Programmer" (Hunt & Thomas)', url: '#', desc: 'Timeless software craft — even more relevant with AI' },
    ],
  },
  {
    category: 'TRY',
    items: [
      { name: 'Claude Code (CLI)', url: 'https://docs.anthropic.com/en/docs/claude-code', desc: 'AI pair programmer in your terminal — what I use daily' },
      { name: 'Cursor / Windsurf', url: 'https://cursor.sh/', desc: 'AI-native code editors' },
      { name: 'Build something with an LLM this weekend', url: '#', desc: 'Seriously. The best way to learn is to ship.' },
    ],
  },
];
---

<section id="rabbit-hole" class="section rabbit-section">
  <div class="container">
    <div class="section-title-wrapper">
      <span class="star-bounce">★</span>
      <h2 class="section-title rabbit-title">DOWN THE RABBIT HOLE</h2>
      <span class="star-bounce star-delay">★</span>
    </div>

    <div class="rabbit-intro boxy-box-sm">
      <p>You're not going to learn this stuff from a lecture. You learn it by going deep. Here's where to start.</p>
    </div>

    <div class="resource-columns">
      {links.map((group) => (
        <div class="resource-group">
          <div class="group-header">
            <span class="group-category">{group.category}</span>
          </div>
          <div class="group-items">
            {group.items.map((item, i) => (
              <div class="resource-item">
                <div class="item-num">[{String(i + 1).padStart(2, '0')}]</div>
                <div class="item-content">
                  <a href={item.url} target="_blank" rel="noopener noreferrer" class="item-name">{item.name}</a>
                  <p class="item-desc">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="terminal-panel">
      <div class="terminal-header">
        <span class="terminal-dots">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
        </span>
        <span class="terminal-label">parting_words.sh</span>
      </div>
      <div class="terminal-body">
        <p class="term-line"><span class="term-prompt">$</span> cat ~/thoughts/final_message.txt</p>
        <p class="term-line term-output">&nbsp;</p>
        <p class="term-line term-output">The developers who thrive in the next decade</p>
        <p class="term-line term-output">won't be the ones who memorize syntax.</p>
        <p class="term-line term-output">&nbsp;</p>
        <p class="term-line term-output">They'll be the ones who learn to think clearly,</p>
        <p class="term-line term-output">communicate precisely, and use every tool</p>
        <p class="term-line term-output">available — including AI — to build things</p>
        <p class="term-line term-output">that matter.</p>
        <p class="term-line term-output">&nbsp;</p>
        <p class="term-line term-output">Be the centaur.</p>
        <p class="term-line term-output">&nbsp;</p>
        <p class="term-line term-output">--- EOF ---</p>
        <p class="term-line"><span class="term-prompt">$</span> <span class="term-cursor">_</span></p>
      </div>
    </div>

    <div class="contact-box boxy-box">
      <p class="contact-text">Questions? Want to chat about AI + dev? Find me after class or reach out online.</p>
      <div class="contact-badges">
        <span class="contact-badge">GitHub: @spencerhenry</span>
        <span class="contact-badge">LinkedIn: Spencer Henry</span>
      </div>
    </div>
  </div>
</section>

<style>
  .rabbit-section {
    background-color: #1A1A2E;
    background-image:
      radial-gradient(circle, rgba(255, 215, 0, 0.04) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .section-title-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .rabbit-title {
    color: var(--yellow);
    text-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
    margin-bottom: 0;
  }

  .star-bounce {
    font-size: 24px;
    color: var(--yellow);
    animation: spin-star 4s linear infinite;
  }

  .star-delay {
    animation-delay: 2s;
  }

  @keyframes spin-star {
    0% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(180deg) scale(1.3); }
    100% { transform: rotate(360deg) scale(1); }
  }

  .rabbit-intro {
    background: rgba(255, 255, 255, 0.05);
    border-color: var(--yellow);
    margin-bottom: 32px;
    text-align: center;
  }

  .rabbit-intro p {
    font-family: var(--font-body);
    font-size: 22px;
    color: #ccc;
    line-height: 1.5;
  }

  /* Resource columns */
  .resource-columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 40px;
  }

  .resource-group {
    background: rgba(255, 255, 255, 0.03);
    border: 2px solid rgba(255, 255, 255, 0.1);
    overflow: hidden;
  }

  .group-header {
    padding: 10px 16px;
    border-bottom: 2px solid rgba(255, 255, 255, 0.1);
  }

  .group-category {
    font-family: var(--font-heading);
    font-size: 12px;
    color: var(--yellow);
    letter-spacing: 2px;
  }

  .group-items {
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .resource-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .item-num {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--yellow);
    flex-shrink: 0;
    opacity: 0.6;
  }

  .item-name {
    font-family: var(--font-body);
    font-size: 20px;
    color: var(--yellow);
    text-decoration: underline;
    display: block;
    margin-bottom: 2px;
  }

  .item-name:hover {
    color: white;
  }

  .item-desc {
    font-family: var(--font-body);
    font-size: 16px;
    color: #888;
    line-height: 1.4;
  }

  /* Terminal */
  .terminal-panel {
    background: #0D0D1A;
    border: var(--border-thick);
    box-shadow: 6px 6px 0 rgba(255, 215, 0, 0.2);
    overflow: hidden;
    margin-bottom: 32px;
  }

  .terminal-header {
    background: #2A2A3E;
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 2px solid #333;
  }

  .terminal-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-red { background: var(--red); }
  .dot-yellow { background: var(--yellow); }
  .dot-green { background: var(--green); }

  .terminal-label {
    font-family: var(--font-ui);
    font-size: 11px;
    color: #888;
  }

  .terminal-body {
    padding: 20px;
  }

  .term-line {
    font-family: var(--font-body);
    font-size: 20px;
    color: var(--green);
    margin-bottom: 2px;
    text-shadow: 0 0 4px rgba(0, 204, 68, 0.4);
  }

  .term-prompt {
    color: var(--yellow);
    margin-right: 8px;
  }

  .term-output {
    color: #88CC88;
    padding-left: 16px;
  }

  .term-cursor {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Contact */
  .contact-box {
    text-align: center;
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .contact-text {
    font-family: var(--font-body);
    font-size: 22px;
    color: #ccc;
    margin-bottom: 16px;
  }

  .contact-badges {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .contact-badge {
    font-family: var(--font-ui);
    font-size: 11px;
    padding: 6px 14px;
    border: 2px solid var(--yellow);
    color: var(--yellow);
    background: rgba(255, 215, 0, 0.1);
  }

  @media (max-width: 768px) {
    .resource-columns {
      grid-template-columns: 1fr;
    }
  }
</style>
