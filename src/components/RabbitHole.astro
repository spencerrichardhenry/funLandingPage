---
const boxes = [
  {
    category: 'HARNESSES — TERMINAL',
    items: [
      { name: 'Claude Code', url: 'https://docs.anthropic.com/en/docs/claude-code' },
      { name: 'OpenCode', url: 'https://opencode.ai/' },
    ],
  },
  {
    category: 'HARNESSES — APPS',
    items: [
      { name: 'Claude', url: 'https://claude.ai/' },
      { name: 'Codex', url: 'https://chatgpt.com/codex' },
      { name: 'Figma Make', url: 'https://www.figma.com/make/' },
    ],
  },
];
---

<section id="rabbit-hole" class="section rabbit-section">
  <div class="container">
    <div class="section-title-wrapper">
      <span class="star-bounce">★</span>
      <h2 class="section-title rabbit-title">DOWN THE RABBIT HOLE</h2>
      <span class="star-bounce star-delay">★</span>
    </div>

    <div class="rabbit-intro boxy-box-sm">
      <p>Time to get your hands dirty. We're going to build a little tool — together, right now.</p>
    </div>

    <!-- Harness boxes + chaos box -->
    <div class="resource-columns">
      {boxes.map((box) => (
        <div class="resource-group">
          <div class="group-header">
            <span class="group-category">{box.category}</span>
          </div>
          <div class="group-items">
            {box.items.map((item) => (
              <div class="resource-item">
                <span class="item-bullet">▸</span>
                <a href={item.url} target="_blank" rel="noopener noreferrer" class="item-name">{item.name}</a>
              </div>
            ))}
          </div>
        </div>
      ))}
      <div class="resource-group chaos-group">
        <div class="group-header chaos-header">
          <span class="group-category">FEELING CHAOTIC?</span>
        </div>
        <div class="group-items">
          <p class="chaos-text">Feel free to go off the rails. Build a different app, take this further, have it do it in X framework or language.</p>
        </div>
      </div>
    </div>

    <!-- Instructions terminal -->
    <div class="terminal-panel">
      <div class="terminal-header">
        <span class="terminal-dots">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
        </span>
        <span class="terminal-label">assignment.sh</span>
      </div>
      <div class="terminal-body">
        <p class="term-line"><span class="term-prompt">$</span> cat ~/lecture/assignment.md</p>
        <p class="term-line term-heading">## BUILD: A Personal To-Do Tracker</p>
        <p class="term-line term-step"><span class="step-num">[1]</span> Open the <a href="/funLandingPage/promptGenerator/" class="term-link-a">Prompt Generator</a></p>
        <p class="term-line term-step"><span class="step-num">[2]</span> Pick a theme: retro 90s, sci-fi, fantasy, deathmetal, etc.</p>
        <p class="term-line term-step"><span class="step-num">[3]</span> Pick a color scheme from <span class="term-link">coolors.co/generate</span></p>
        <p class="term-line term-step"><span class="step-num">[4]</span> Describe your data model</p>
        <p class="term-line term-step"><span class="step-num">[5]</span> Pick a framework / language</p>
        <p class="term-line term-step"><span class="step-num">[6]</span> Hit generate, copy the prompt, let 'er rip</p>
        <p class="term-line term-output">--- GOOD LUCK ---</p>
        <p class="term-line"><span class="term-prompt">$</span> <span class="term-cursor">_</span></p>
      </div>
    </div>

    <div class="contact-box boxy-box">
      <p class="contact-text">Questions? Want to chat about LLMs + dev? Shoot me an email.</p>
      <div class="contact-badges">
        <span class="contact-badge">spencerrichardhenry@gmail.com</span>
      </div>
    </div>
  </div>
</section>

<style>
  .rabbit-section {
    background-color: #1A1A2E;
    background-image:
      radial-gradient(circle, rgba(255, 215, 0, 0.04) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .section-title-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .rabbit-title {
    color: var(--yellow);
    text-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
    margin-bottom: 0;
  }

  .star-bounce {
    font-size: 24px;
    color: var(--yellow);
    animation: spin-star 4s linear infinite;
  }

  .star-delay {
    animation-delay: 2s;
  }

  @keyframes spin-star {
    0% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(180deg) scale(1.3); }
    100% { transform: rotate(360deg) scale(1); }
  }

  .rabbit-intro {
    background: rgba(255, 255, 255, 0.05);
    border-color: var(--yellow);
    margin-bottom: 32px;
    text-align: center;
  }

  .rabbit-intro p {
    font-family: var(--font-body);
    font-size: 22px;
    color: #ccc;
    line-height: 1.5;
  }

  /* Resource columns */
  .resource-columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 40px;
  }

  .resource-group {
    background: rgba(255, 255, 255, 0.03);
    border: 2px solid rgba(255, 255, 255, 0.1);
    overflow: hidden;
  }

  .group-header {
    padding: 10px 16px;
    border-bottom: 2px solid rgba(255, 255, 255, 0.1);
  }

  .group-category {
    font-family: var(--font-heading);
    font-size: 10px;
    color: var(--yellow);
    letter-spacing: 2px;
  }

  .group-items {
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .resource-item {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .item-bullet {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--green);
    flex-shrink: 0;
  }

  .item-name {
    font-family: var(--font-body);
    font-size: 22px;
    color: var(--yellow);
    text-decoration: underline;
  }

  .item-name:hover {
    color: white;
  }

  /* Chaos box */
  .chaos-group {
    border-color: rgba(255, 0, 64, 0.3);
  }

  .chaos-header {
    border-bottom-color: rgba(255, 0, 64, 0.3);
  }

  .chaos-group .group-category {
    color: var(--red);
  }

  .chaos-text {
    font-family: var(--font-body);
    font-size: 18px;
    color: #ccc;
    line-height: 1.5;
  }

  /* Terminal */
  .terminal-panel {
    background: #0D0D1A;
    border: var(--border-thick);
    box-shadow: 6px 6px 0 rgba(255, 215, 0, 0.2);
    overflow: hidden;
    margin-bottom: 32px;
  }

  .terminal-header {
    background: #2A2A3E;
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 2px solid #333;
  }

  .terminal-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-red { background: var(--red); }
  .dot-yellow { background: var(--yellow); }
  .dot-green { background: var(--green); }

  .terminal-label {
    font-family: var(--font-ui);
    font-size: 11px;
    color: #888;
  }

  .terminal-body {
    padding: 20px;
  }

  .term-line {
    font-family: var(--font-body);
    font-size: 20px;
    color: var(--green);
    margin-bottom: 2px;
    text-shadow: 0 0 4px rgba(0, 204, 68, 0.4);
  }

  .term-prompt {
    color: var(--yellow);
    margin-right: 8px;
  }

  .term-output {
    color: #88CC88;
    padding-left: 16px;
  }

  .term-heading {
    color: var(--yellow);
    padding-left: 16px;
    margin-bottom: 4px;
  }

  .term-step {
    color: var(--green);
    padding-left: 16px;
  }

  .step-num {
    color: var(--yellow);
    margin-right: 6px;
  }

  .term-link {
    color: var(--yellow);
    text-decoration: underline;
    opacity: 0.8;
  }

  .term-link-a {
    color: var(--yellow);
    text-decoration: underline;
    font-weight: bold;
  }

  .term-link-a:hover {
    color: white;
  }

  .term-cursor {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Contact */
  .contact-box {
    text-align: center;
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .contact-text {
    font-family: var(--font-body);
    font-size: 22px;
    color: #ccc;
    margin-bottom: 16px;
  }

  .contact-badges {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .contact-badge {
    font-family: var(--font-ui);
    font-size: 11px;
    padding: 6px 14px;
    border: 2px solid var(--yellow);
    color: var(--yellow);
    background: rgba(255, 215, 0, 0.1);
  }

  @media (max-width: 768px) {
    .resource-columns {
      grid-template-columns: 1fr;
    }
  }
</style>
