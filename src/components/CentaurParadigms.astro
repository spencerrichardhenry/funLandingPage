---
---

<section id="centaur" class="section centaur-section">
  <div class="container">
    <h2 class="section-title">CENTAUR vs. REVERSE CENTAUR</h2>

    <div class="paradigm-grid">
      <!-- Centaur -->
      <div class="paradigm-window">
        <div class="window-titlebar win95-raised">
          <span class="window-dots">
            <span class="dot dot-red"></span>
            <span class="dot dot-yellow"></span>
            <span class="dot dot-green"></span>
          </span>
          <span class="window-title">centaur.exe</span>
          <div class="window-controls">
            <span class="win-btn">_</span>
            <span class="win-btn">□</span>
            <span class="win-btn">×</span>
          </div>
        </div>
        <div class="window-body centaur-body">
          <div class="paradigm-icon">
            <!-- Human head on robot body -->
            <svg viewBox="0 0 80 120" width="80" height="120" class="centaur-svg">
              <!-- Human head -->
              <circle cx="40" cy="18" r="14" fill="#F5CBA7" stroke="#222" stroke-width="2.5"/>
              <circle cx="34" cy="15" r="2" fill="#222"/>
              <circle cx="46" cy="15" r="2" fill="#222"/>
              <path d="M35 23 Q40 27 45 23" fill="none" stroke="#222" stroke-width="1.5"/>
              <!-- Hair -->
              <path d="M26 14 Q28 4 40 4 Q52 4 54 14" fill="#6B4226" stroke="#222" stroke-width="1.5"/>
              <!-- Neck -->
              <rect x="36" y="32" width="8" height="6" fill="#F5CBA7" stroke="#222" stroke-width="1.5"/>
              <!-- Robot torso -->
              <rect x="22" y="38" width="36" height="30" rx="3" fill="#C0C0C0" stroke="#222" stroke-width="2.5"/>
              <rect x="32" y="44" width="16" height="8" rx="1" fill="#0066FF" stroke="#222" stroke-width="1"/>
              <circle cx="40" cy="60" r="3" fill="#00CC44"/>
              <!-- Robot arms -->
              <rect x="10" y="40" width="10" height="24" rx="3" fill="#A0A0A0" stroke="#222" stroke-width="2"/>
              <rect x="60" y="40" width="10" height="24" rx="3" fill="#A0A0A0" stroke="#222" stroke-width="2"/>
              <!-- Robot legs -->
              <rect x="26" y="70" width="11" height="28" rx="2" fill="#A0A0A0" stroke="#222" stroke-width="2"/>
              <rect x="43" y="70" width="11" height="28" rx="2" fill="#A0A0A0" stroke="#222" stroke-width="2"/>
              <!-- Feet -->
              <rect x="23" y="96" width="17" height="6" rx="2" fill="#808080" stroke="#222" stroke-width="2"/>
              <rect x="40" y="96" width="17" height="6" rx="2" fill="#808080" stroke="#222" stroke-width="2"/>
            </svg>
          </div>
          <h3 class="paradigm-name">THE CENTAUR</h3>
          <p class="paradigm-subtitle">Human-led, LLM-assisted</p>
          <div class="paradigm-divider"></div>
          <div class="paradigm-desc">
            <p>The human drives strategy, makes decisions, gets the credit. LLMs help with tedium and precision</p>
          </div>
          <div class="paradigm-traits">
            <div class="trait">
              <span class="trait-bullet">▸</span>
              <span class="trait-value">Ship safer code</span>
            </div>
            <div class="trait">
              <span class="trait-bullet">▸</span>
              <span class="trait-value">Spend less time on tedium</span>
            </div>
            <div class="trait">
              <span class="trait-bullet">▸</span>
              <span class="trait-value">Get to build more ambitious versions of things</span>
            </div>
                        <div class="trait">
              <span class="trait-bullet">▸</span>
              <span class="trait-value">Upskill super quickly</span>
            </div>
          </div>
          <div class="paradigm-verdict verdict-good">
            <span class="verdict-icon">✓</span>
            <span>THIS IS WHERE YOU WANT TO BE</span>
          </div>
        </div>
      </div>

      <!-- Reverse Centaur -->
      <div class="paradigm-window reverse-window">
        <div class="window-titlebar win95-raised">
          <span class="window-dots">
            <span class="dot dot-red"></span>
            <span class="dot dot-yellow"></span>
            <span class="dot dot-green"></span>
          </span>
          <span class="window-title">reverse_centaur.exe</span>
          <div class="window-controls">
            <span class="win-btn">_</span>
            <span class="win-btn">□</span>
            <span class="win-btn">×</span>
          </div>
        </div>
        <div class="window-body reverse-body">
          <div class="paradigm-icon">
            <!-- Robot head plopped right on legs, no body -->
            <svg viewBox="0 0 80 80" width="80" height="80" class="centaur-svg" style="margin-bottom:40px">
              <!-- Human legs (jeans) -->
              <rect x="26" y="32" width="12" height="30" rx="1" fill="#4A6FA5" stroke="#222" stroke-width="2"/>
              <rect x="42" y="32" width="12" height="30" rx="1" fill="#4A6FA5" stroke="#222" stroke-width="2"/>
              <!-- Shoes -->
              <rect x="24" y="60" width="16" height="7" rx="3" fill="#5C4033" stroke="#222" stroke-width="2"/>
              <rect x="40" y="60" width="16" height="7" rx="3" fill="#5C4033" stroke="#222" stroke-width="2"/>
              <!-- Robot head sitting directly on the legs -->
              <rect x="24" y="4" width="32" height="28" rx="4" fill="#C0C0C0" stroke="#222" stroke-width="2.5"/>
              <rect x="30" y="12" width="8" height="5" rx="1" fill="#FF0040" stroke="#222" stroke-width="1"/>
              <rect x="42" y="12" width="8" height="5" rx="1" fill="#FF0040" stroke="#222" stroke-width="1"/>
              <rect x="33" y="22" width="14" height="3" rx="1" fill="#808080" stroke="#222" stroke-width="1"/>
              <!-- Antenna -->
              <line x1="40" y1="4" x2="40" y2="-2" stroke="#222" stroke-width="2"/>
              <circle cx="40" cy="-4" r="3" fill="#FF0040" stroke="#222" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="paradigm-name paradigm-name-danger">THE REVERSE CENTAUR</h3>
          <p class="paradigm-subtitle">LLM-led, human-assisted</p>
          <div class="paradigm-divider"></div>
          <div class="paradigm-desc">
            <p>LLMs drive the work, humans act as the gatekeeper or quality control.</p>
          </div>
          <div class="paradigm-traits">
            <div class="trait">
              <span class="trait-bullet trait-bullet-bad">▸</span>
              <span class="trait-value">Liability cushion</span>
            </div>
            <div class="trait">
              <span class="trait-bullet trait-bullet-bad">▸</span>
              <span class="trait-value">Review X plans per day</span>
            </div>
            <div class="trait">
              <span class="trait-bullet trait-bullet-bad">▸</span>
              <span class="trait-value">Test X features per day</span>
            </div>
                        <div class="trait">
              <span class="trait-bullet trait-bullet-bad">▸</span>
              <span class="trait-value">"LLM does that, why do I need to know?"</span>
            </div>
          </div>
          <div class="paradigm-verdict verdict-bad">
            <span class="verdict-icon">✗</span>
            <span>THE TRAP TO AVOID</span>
          </div>
        </div>
        <!-- Win95 error popup -->
        <div class="error-popup">
          <div class="error-titlebar">
            <span class="error-title-text">⚠ reality_check.exe</span>
            <span class="error-close">×</span>
          </div>
          <div class="error-body">
            <div class="error-icon">⚠</div>
            <p class="error-msg">This is the vision that VC hype is pitching to execs.</p>
          </div>
          <div class="error-buttons">
            <button class="error-btn win95-raised">OK</button>
          </div>
        </div>
      </div>
    </div>



  </div>
</section>

<style>
  .centaur-section {
    background-color: var(--bg-teal);
    background-image:
      radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .centaur-section .section-title {
    color: white;
    text-shadow: 2px 2px 0 rgba(0,0,0,0.3);
  }

  .paradigm-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 40px;
  }

  /* Windows */
  .paradigm-window {
    border: var(--border-thick);
    box-shadow: var(--shadow-boxy);
    overflow: hidden;
  }

  .window-titlebar {
    background: var(--bg-gray);
    padding: 4px 8px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 2px solid #999;
  }

  .window-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-red { background: var(--red); }
  .dot-yellow { background: var(--yellow); }
  .dot-green { background: var(--green); }

  .window-title {
    font-family: var(--font-ui);
    font-size: 11px;
    color: #222;
    flex: 1;
  }

  .window-controls {
    display: flex;
    gap: 4px;
  }

  .win-btn {
    font-family: var(--font-body);
    font-size: 16px;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-gray);
    border: 1px solid #888;
    cursor: default;
  }

  .window-body {
    padding: 24px;
    background: white;
  }

  .centaur-body {
    border-left: 6px solid var(--green);
  }

  .reverse-body {
    border-left: 6px solid var(--red);
  }

  .paradigm-icon {
    margin-bottom: 12px;
    display: flex;
    justify-content: center;
  }

  .centaur-svg {
    display: block;
    overflow: visible;
  }

  .paradigm-name {
    font-family: var(--font-heading);
    font-size: clamp(11px, 1.8vw, 16px);
    color: var(--green);
    margin-bottom: 4px;
  }

  .paradigm-name-danger {
    color: var(--red);
  }

  .paradigm-subtitle {
    font-family: var(--font-ui);
    font-size: 12px;
    color: #888;
    margin-bottom: 12px;
  }

  .paradigm-divider {
    height: 2px;
    background: #eee;
    margin-bottom: 16px;
  }

  .paradigm-desc p {
    font-family: var(--font-body);
    font-size: 20px;
    color: #444;
    line-height: 1.5;
    margin-bottom: 16px;
  }

  .paradigm-traits {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 16px;
  }

  .trait {
    display: flex;
    gap: 8px;
    align-items: baseline;
  }

  .trait-bullet {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--green);
    flex-shrink: 0;
  }

  .trait-bullet-bad {
    color: var(--red);
  }

  .trait-value {
    font-family: var(--font-body);
    font-size: 18px;
    color: #444;
  }

  .paradigm-verdict {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    font-family: var(--font-heading);
    font-size: 10px;
    letter-spacing: 1px;
  }

  .verdict-good {
    background: #E8F5E9;
    border: 2px solid var(--green);
    color: var(--green);
  }

  .verdict-bad {
    background: #FFEBEE;
    border: 2px solid var(--red);
    color: var(--red);
  }

  .verdict-icon {
    font-size: 16px;
    font-weight: bold;
  }

  /* Win95 error popup */
  .reverse-window {
    position: relative;
  }

  .error-popup {
    position: absolute;
    top: 290px;
    left: 220px;
    width: 260px;
    background: var(--bg-gray);
    border: 2px solid #222;
    box-shadow: 4px 4px 0 rgba(0,0,0,0.4);
    z-index: 10;
    border-top: 2px solid var(--win95-highlight);
    border-left: 2px solid var(--win95-highlight);
    border-bottom: 2px solid var(--win95-dark-shadow);
    border-right: 2px solid var(--win95-dark-shadow);
  }

  .error-titlebar {
    background: #000080;
    padding: 3px 6px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid #000060;
  }

  .error-title-text {
    font-family: var(--font-ui);
    font-size: 10px;
    color: white;
    font-weight: 700;
  }

  .error-close {
    font-family: var(--font-body);
    font-size: 16px;
    color: #222;
    background: var(--bg-gray);
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-top: 1px solid var(--win95-highlight);
    border-left: 1px solid var(--win95-highlight);
    border-bottom: 1px solid var(--win95-dark-shadow);
    border-right: 1px solid var(--win95-dark-shadow);
    line-height: 1;
  }

  .error-body {
    padding: 16px 12px 8px;
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .error-icon {
    font-size: 28px;
    flex-shrink: 0;
    line-height: 1;
  }

  .error-msg {
    font-family: var(--font-body);
    font-size: 17px;
    color: #222;
    line-height: 1.4;
  }

  .error-buttons {
    display: flex;
    justify-content: center;
    padding: 4px 12px 12px;
  }

  .error-btn {
    font-family: var(--font-ui);
    font-size: 11px;
    padding: 3px 24px;
    background: var(--bg-gray);
    border: none;
    cursor: default;
  }

  @media (max-width: 768px) {
    .paradigm-grid {
      grid-template-columns: 1fr;
    }
    .error-popup {
      right: 0;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const popup = document.querySelector('.error-popup');
    const titlebar = popup.querySelector('.error-titlebar');
    const container = popup.parentElement;

    let dragging = false;
    let offsetX = 0;
    let offsetY = 0;

    titlebar.style.cursor = 'grab';

    titlebar.addEventListener('mousedown', (e) => {
      dragging = true;
      titlebar.style.cursor = 'grabbing';
      const rect = popup.getBoundingClientRect();
      offsetX = e.clientX - rect.left;
      offsetY = e.clientY - rect.top;
      e.preventDefault();
    });

    document.addEventListener('mousemove', (e) => {
      if (!dragging) return;
      const containerRect = container.getBoundingClientRect();
      let x = e.clientX - containerRect.left - offsetX;
      let y = e.clientY - containerRect.top - offsetY;

      // Clamp within the reverse-centaur window
      const maxX = containerRect.width - popup.offsetWidth;
      const maxY = containerRect.height - popup.offsetHeight;
      x = Math.max(0, Math.min(x, maxX));
      y = Math.max(0, Math.min(y, maxY));

      popup.style.position = 'absolute';
      popup.style.left = x + 'px';
      popup.style.top = y + 'px';
      popup.style.right = 'auto';
      popup.style.bottom = 'auto';
    });

    document.addEventListener('mouseup', () => {
      if (dragging) {
        dragging = false;
        titlebar.style.cursor = 'grab';
      }
    });
  });
</script>
