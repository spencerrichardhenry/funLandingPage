---
---

<section id="agentic-vs-chat" class="section agentic-section">
  <div class="container">
    <h2 class="section-title agentic-title">LLM IN A CHAT vs. AN AGENT IN A HARNESS</h2>

    <!-- Big visual comparison -->
    <div class="visual-comparison">
      <!-- Left: lonely PC -->
      <div class="visual-side visual-chat">
        <div class="lonely-pc">
          <div class="pc-monitor">
            <div class="pc-screen">
              <div class="screen-scroll">
                <div class="screen-text-block">
                  {Array.from({ length: 80 }).map(() => (
                    <Fragment>
                      <span class="sl">&gt; please help</span>
                      <span class="sl">&gt; *copies*</span>
                      <span class="sl">&gt; *pastes*</span>
                      <span class="sl">&gt; hmm that didn't work</span>
                      <span class="sl">&gt; *copies error*</span>
                      <span class="sl">&gt; *pastes*</span>
                    </Fragment>
                  ))}
                </div>
              </div>
            </div>
            <div class="pc-stand"></div>
          </div>
          <div class="pc-label">A brain in a jar</div>
          <div class="chat-floats">
            <span class="float-txt" style="top:5%;left:2%;animation-delay:0s">ctrl+c</span>
            <span class="float-txt" style="top:70%;left:8%;animation-delay:1.2s">ctrl+v</span>
            <span class="float-txt" style="top:25%;right:5%;animation-delay:0.6s">ctrl+c</span>
            <span class="float-txt" style="top:80%;right:2%;animation-delay:1.8s">ctrl+v</span>
          </div>
        </div>
      </div>

      <!-- Center divider -->
      <div class="vs-divider">
        <span class="vs-text">vs.</span>
      </div>

      <!-- Right: connected web -->
      <div class="visual-side visual-agent">
        <div class="web-container">
          <!-- Center node: AGENT -->
          <div class="web-node web-agent" style="top:42%;left:42%">
            <span>AGENT</span>
          </div>
          <!-- YOU node -->
          <div class="web-node web-you" style="top:42%;left:22%">
            <span>YOU</span>
          </div>
          <!-- Surrounding tool nodes -->
          <div class="web-node web-tool" style="top:5%;left:55%">
            <span>📁 Files</span>
          </div>
          <div class="web-node web-tool" style="top:5%;left:20%">
            <span>🌐 Browser</span>
          </div>
          <div class="web-node web-tool" style="top:28%;left:75%">
            <span>⚡ Terminal</span>
          </div>
          <div class="web-node web-tool" style="top:58%;left:78%">
            <span>📊 Spreadsheets</span>
          </div>
          <div class="web-node web-tool" style="top:80%;left:55%">
            <span>✉️ Email</span>
          </div>
          <div class="web-node web-tool" style="top:80%;left:18%">
            <span>🛒 Grocery Orders</span>
          </div>
          <div class="web-node web-tool" style="top:58%;left:5%">
            <span>📝 Paperwork</span>
          </div>
          <!-- SVG lines connecting agent to everything -->
          <svg class="web-lines" viewBox="0 0 400 300" preserveAspectRatio="none">
            <!-- you to agent -->
            <line x1="120" y1="150" x2="175" y2="150" class="web-line line-you" />
            <!-- agent to tools -->
            <line x1="210" y1="140" x2="245" y2="35" class="web-line" />
            <line x1="190" y1="130" x2="120" y2="35" class="web-line" />
            <line x1="220" y1="140" x2="325" y2="100" class="web-line" />
            <line x1="220" y1="165" x2="335" y2="195" class="web-line" />
            <line x1="210" y1="175" x2="245" y2="260" class="web-line" />
            <line x1="185" y1="175" x2="105" y2="260" class="web-line" />
            <line x1="175" y1="165" x2="45" y2="195" class="web-line" />
          </svg>
        </div>
        <div class="agent-label">A brain with hands</div>
      </div>
    </div>

    <div class="key-point boxy-box">
      <p><strong>THE KEY INSIGHT:</strong> The LLM is the same in both cases. The difference is what it can touch. A harness turns a chatbot into a coworker.</p>
    </div>
  </div>
</section>

<style>
  .agentic-section {
    background-color: #1A1A2E;
    background-image:
      radial-gradient(circle, rgba(0, 204, 68, 0.03) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  .agentic-title {
    color: var(--green);
    text-shadow: 0 0 10px rgba(0, 204, 68, 0.3);
    font-size: clamp(12px, 2.2vw, 22px);
  }

  /* Big visual */
  .visual-comparison {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: stretch;
    margin-bottom: 40px;
    min-height: 400px;
  }

  .visual-side {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px 16px;
    position: relative;
  }

  /* VS divider */
  .vs-divider {
    width: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .vs-text {
    font-family: var(--font-heading);
    font-size: clamp(14px, 2vw, 22px);
    color: #555;
    text-transform: uppercase;
  }

  /* ===== LEFT: Lonely PC ===== */
  .visual-chat {
    background: rgba(255, 255, 255, 0.02);
    border: 2px dashed rgba(255, 255, 255, 0.08);
  }

  .lonely-pc {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .pc-monitor {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .pc-screen {
    width: 200px;
    height: 160px;
    background: #0a0a1a;
    border: 6px solid #555;
    border-radius: 4px;
    padding: 12px;
    overflow: hidden;
    position: relative;
    box-shadow: inset 0 0 20px rgba(0, 204, 68, 0.05);
  }

  .screen-scroll {
    overflow: hidden;
    height: 100%;
  }

  .screen-text-block {
    display: flex;
    flex-direction: column;
    animation: scroll-text 600s linear infinite;
  }

  .screen-text-block .sl {
    font-family: var(--font-body);
    font-size: 14px;
    color: #556655;
    line-height: 1.6;
    white-space: nowrap;
  }

  @keyframes scroll-text {
    0% { transform: translateY(0); }
    100% { transform: translateY(-50%); }
  }

  .pc-stand {
    width: 40px;
    height: 20px;
    background: #555;
    clip-path: polygon(15% 0, 85% 0, 100% 100%, 0% 100%);
  }

  .pc-label {
    font-family: var(--font-heading);
    font-size: 10px;
    color: #666;
    margin-top: 16px;
    letter-spacing: 1px;
  }

  .chat-floats {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .float-txt {
    position: absolute;
    font-family: var(--font-body);
    font-size: 14px;
    color: #444;
    animation: float-fade 3s ease-in-out infinite;
  }

  @keyframes float-fade {
    0%, 100% { opacity: 0.2; transform: translateY(0); }
    50% { opacity: 0.5; transform: translateY(-8px); }
  }

  /* ===== RIGHT: Connected Web ===== */
  .visual-agent {
    background: rgba(0, 204, 68, 0.03);
    border: 2px solid rgba(0, 204, 68, 0.15);
  }

  .web-container {
    position: relative;
    width: 100%;
    max-width: 400px;
    height: 300px;
  }

  .web-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .web-line {
    stroke: rgba(0, 204, 68, 0.25);
    stroke-width: 1.5;
    stroke-dasharray: 6 4;
    animation: dash-flow 2s linear infinite;
  }

  .line-you {
    stroke: rgba(0, 102, 255, 0.4);
    stroke-width: 2.5;
    stroke-dasharray: 8 4;
  }

  @keyframes dash-flow {
    0% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: -20; }
  }

  .web-node {
    position: absolute;
    font-family: var(--font-ui);
    font-size: 9px;
    padding: 6px 10px;
    border-radius: 2px;
    white-space: nowrap;
    z-index: 2;
  }

  .web-agent {
    background: var(--green);
    color: #111;
    font-family: var(--font-heading);
    font-size: 10px;
    padding: 10px 16px;
    border: 2px solid #222;
    box-shadow: 0 0 12px rgba(0, 204, 68, 0.3);
    animation: pulse-glow 2s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 12px rgba(0, 204, 68, 0.3); }
    50% { box-shadow: 0 0 24px rgba(0, 204, 68, 0.5); }
  }

  .web-you {
    background: var(--blue);
    color: white;
    font-family: var(--font-heading);
    font-size: 10px;
    padding: 10px 16px;
    border: 2px solid #222;
  }

  .web-tool {
    background: rgba(255, 255, 255, 0.08);
    color: #ccc;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .agent-label {
    font-family: var(--font-heading);
    font-size: 10px;
    color: var(--green);
    margin-top: 16px;
    letter-spacing: 1px;
    text-align: center;
  }

  /* Key point */
  .key-point {
    background: rgba(255, 215, 0, 0.1);
    border-color: var(--yellow);
  }

  .key-point p {
    font-family: var(--font-body);
    font-size: 22px;
    color: #ddd;
    line-height: 1.5;
  }

  .key-point strong {
    font-family: var(--font-heading);
    font-size: 12px;
    color: var(--yellow);
  }

  @media (max-width: 768px) {
    .visual-comparison {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .vs-divider {
      height: 40px;
    }
    .web-container {
      height: 250px;
    }
  }
</style>
